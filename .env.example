NEXT_PUBLIC_API_BASE_URL=https://polaria-wms-api.onrender.com
NEXT_PUBLIC_WMS_LOGIN_URL=https://polaria-wms-web.vercel.app/

# Supabase (historial de conversaciones Mateo)
# URL base del proyecto (sin /rest/v1 al final)
NEXT_PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co
# Service role key (Settings → API → service_role). Solo servidor, nunca NEXT_PUBLIC_
SUPABASE_SERVICE_ROLE_KEY=tu-service-role-key

# En localhost el login directo se habilita automáticamente.
# Forzar en otros entornos: true | false
# NEXT_PUBLIC_ALLOW_DIRECT_LOGIN=true
